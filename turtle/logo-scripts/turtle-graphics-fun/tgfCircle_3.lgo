; Similar to the circle function from
; https://www.turtlegraphics.fun
; when 3 parameters are specified
to tgfCircle_3 :radius :angle :clockwise?
	localmake "oldState turtleState
	jumpForward :radius
	ifelse :clockwise? [
		right 90
		arcRight :angle :radius
	] [
		left 90
		arcLeft :angle :radius
	]
	setTurtleState :oldState
end