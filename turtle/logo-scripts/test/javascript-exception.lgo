to liberiaFlagStripes :width :height
	localmake "oldState turtleState
	localmake "stripeThickness :height / 11
	setLineCap "butt
	setPenColor "white
	setPenSize :width
	forward :height
	setPenColor "#002868
	repeat 6 [
		backward :stripeThickness
		jumpBackward :stripeThickness
	]
	setTurtleState :oldState
end

to liberiaFlag :height
	localmake "width :height * 1140 / 600
	localmake "starWidth 
	liberiaFlagStripes :width :height
	setPenColor "#002868
	jumpLeft (:width - :starWidth) / 2
end

liberiaFlag 100
imageAlpha 100 * 1140 / 600 100 'local://liberia.svg' 0.5