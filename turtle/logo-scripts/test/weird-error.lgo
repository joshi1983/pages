		[96 0] [-7 2.5] [-26.7 0.4] [51 0.05]
		[5 2] [19 0.3] [-40 0.25]
	]
	setPenSize 0
	setFillColor "#187741
	polyStart
	arcsLeft :arcsInfo :size
	polyEnd
	jumpTo :oldPos
	setHeading :oldHeading
	jumpForward :size * 0.235
	jumpRight :size * 0.04
	leafBranches :size
end

