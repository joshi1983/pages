	jumpRight :height * 0.186
	drawI :fontSize1
	jumpRight :height * 0.217
	drawN :fontSize1
	jumpRight :height * 0.3
	drawG :fontSize1

	jumpTo :oldPos
	jumpLeft :height * 1.935
	jumpForward :height * 0.68
	drawLeafs :height * 0.26395
	setTurtleState :oldState
end

