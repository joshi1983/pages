; Inspired by a drawing shown at:
; https://www.youtube.com/watch?v=Ir0yx_yv9R8
; This is a rough translation from Saanvi's Kojo code to WebLogo.

setScreenColor "black
setFillColor mix "pink transparent 0.1
setPenColor "white
repeat 18 [
	polyStart
	repeat 6 [
		arcRight 150 50
		left 90
	]
	polyEnd
	right 20
]