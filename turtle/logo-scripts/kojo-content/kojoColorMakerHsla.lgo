; Similar to ColorMaker.hsla function from Kojo
; hue should be in the range 0..360.
; saturation should be in the range 0..1
; luminosity should be in range 0..1
; alpha should be in range 0..1
to kojoColorMakerHsla :hue :saturation :luminosity :alpha
	output mix (hslToRGB :hue / 360 :saturation :luminosity) transparent 1 - :alpha
end