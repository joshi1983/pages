; The following is copied from a script found at:
; https://fmslogo.blogspot.com/2014/07/fms-logo.html

setpensize 5
penup
left 90
forward 150
right 90
pendown

; draw rectangle for main floors of house.
repeat 4 [
	forward 250
	right 90
]
penup
forward 250
pendown

; draw roof of house.
left 90
forward 40
right 135
forward 233.5
right 90
forward 233.5
right 135
forward 40

