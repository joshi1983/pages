; Inspired by logo at:
; https://www.youtube.com/@CollapseCo
to collapseCoLogo :height
	localmake "oldState turtleState
	localmake "arcAngleGap 60
	localmake "arcAngle 360 - :arcAngleGap
	jumpForward :height / 2
	setPenSize :height * 0.125
	setPenColor "white
	setLineCap "butt
	left 90 - :arcAngleGap / 2
	arc :arcAngle :height * 0.295
	setPenSize :height * 0.1
	arc :arcAngle :height * 0.14
	setTurtleState :oldState
end

setScreenColor "#592182
collapseCoLogo 100