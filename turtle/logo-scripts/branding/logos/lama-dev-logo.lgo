to drawNose :height
	localmake "oldState turtleState
	setPenSize 0
	setFillColor "#9a8687
	drawArcLineShape [0.338 0.29
		[[-23 0] [0.07] [178 0] [-60 0.02] [-25 0.07] [32 0.07]
		[140 0] [0.04]]
	] :height

	setFillColor "black
	drawArcLineShape [0.236 0.35
		[[-90 0] [0.05] [-63 0.045] [-20 0.15] [-89 0.04]
		[-55 0.13] [-177.5 0] [50 0.13] [40 0.055] [50 0.025]
		[40 0.07] [30 0.1]]
	] :height
	drawArcLineShape [0.3517 0.2409
		[[100 0] [-30 0.025] [-60 0.01] [120 0] [0.01] [102 0]
		[60 0.025]]
	] :height
	setTurtleState :oldState
end

to drawWhiteHair :height
	localmake "oldState turtleState
	setPenSize 0
	setFillColor "white
	drawArcLineShape [-0.09 0.7133
		[[-50 0] [-40 0.2] [-40 0.04] [0.04] [100 0] [-60 0.11]
		[-50 0.04] [-24 0.1] [-75 0.03] [170 0] [-28 0.13]
		[-100 0.06] [-90 0.01] [170 0] [0.04] [-150 0.03] [-30 0.1]
		[-5 0.2] [0.03] [120 0] [0.02] [-115 0.04] [-40 0.11]
		[150 0] [-90 0.07] [-18 0.4] [-50 0.1] [-40 0.02] [40 0.1]]
	] :height

	setTurtleState :oldState
end

to drawHeart :height
	localmake "oldState turtleState
	localmake "line1 [
		[75 0] [-64 0.8] [-163.0899 0.31]
		[152.0899 - 90 0]
	]
	drawArcLineShape [0 0
		combine :line1 reverse :line1
	] :height
	setTurtleState :oldState
end

to drawHeartGlasses :height
	localmake "oldState turtleState
	localmake "oldPos pos
	setPenColor "red
	setFillColor penColor
	setPenSize 0
	jumpForward :height * 0.337
	jumpRight :height * 0.132
	drawHeart :height * 0.2
	jumpRight :height * 0.245
	jumpForward :height * 0.04
	drawHeart :height * 0.15

	jumpTo :oldPos
	setPenSize :height * 0.005
	jumpForward :height * 0.475
	jumpRight :height * 0.245
	right 30
	arcRight 120 :height * 0.033
	setTurtleState :oldState
end

; Inspired by logo at:
; https://www.youtube.com/@LamaDev
to lamaDevLogo :height
	localmake "oldState turtleState
	localmake "oldPos pos
	localmake "oldHeading heading
	localmake "radius :height * 0.485
	jumpForward :height - :radius
	setPenSize 0
	setFillColor "#fd0
	circle :radius
	setFillColor "#d9e5e3
	jumpTo :oldPos
	drawArcLineShape [0 0
		[[90 0] [-58 0.44] [-40 0] [-13 1.5] [-90 0.3]
		[-12 0] [0.3] [-20 0] [-20 0.2] [-60 0] [0.08]
		[78 0] [-11 0.4] [-90 0.01] [0.01] [90 0] [-23 0.2]
		[-65 0.02] [-20 0.1] [70 0] [-70 0.1] [45 0.03] [0.15]
		[-50 0.05]]
	] :height
	jumpForward :height * 0.67
	jumpRight :height * 0.18
	right 25
	arcPair :height * 0.17 70

	jumpTo :oldPos
	setHeading :oldHeading
	jumpForward :height * 0.55
	jumpLeft :height * 0.18
	right 9
	setPenColor fillColor
	setPenSize :height * 0.05
	setLineJoinStyle "round
	arcPair :height * 0.27 80
	setFillColor "#9e8682
	setPenSize 0
	jumpForward :height * 0.04
	arcPair :height * 0.24 70

	jumpTo :oldPos
	setHeading :oldHeading
	drawWhiteHair :height
	drawNose :height
	drawHeartGlasses :height
	setTurtleState :oldState
end

lamaDevLogo 100