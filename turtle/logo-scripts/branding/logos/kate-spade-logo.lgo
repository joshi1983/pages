; Inspired by logo at:
; https://www.katespade.com
to kateSpadeLogo :height
	localmake "oldState turtleState
	localmake "line [
		[0.217] [-90 0.014] [-36 0.06] [-10 0.5]
		[0.04] [47.7 0.238] [140 0.01] [-12 0.21] [-30 0.31]
		[-60 0.195] [-20 0.3] [-30 0.195] [-30 0.32] [-13.7 0.8]
		[0.15] [10.6 1.2]
	]
	setPenSize 0
	setFillColor "black
	drawArcLineShape [0 0
		pathMirror :line
	] :height / item 2 arcLinesInfo :line

	setTurtleState :oldState
end

kateSpadeLogo 100