; Inspired by logo at:
; https://www.alz.org
to alzeimersAssociationLogo :height
	localmake "oldState turtleState
	jumpForward :height / 2
	setPenSize 0
	setFillColor "#4a0d66
	repeat 2 [
		drawArcLineShape [-0.061 0
			[[-38 0] [0.047] [296 0.224] [-78 0.063] [0.283] [-90 0.012]
			[0.082] [-90 0.012] [0.24] [68.8 0.025] [-270 0.325] [-20 0.275]]
		] :height
		right 180
	]
	setTurtleState :oldState
end

