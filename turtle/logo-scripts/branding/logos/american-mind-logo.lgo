; Inspired by logo at:
; https://americanmind.org
to americanMindLogo :height
	localmake "oldState turtleState
	localmake "width :height * 2.25
	localmake "separation :width - :height
	localmake "stripeHeight :height * 0.165
	jumpLeft :separation / 2
	stripes :height :height ["#045fc7]
	jumpRight :separation
	repeat 3 [
		stripes :height :stripeHeight ["#e21b1b]
		jumpForward (:height - :stripeHeight) / 2
	]
	setTurtleState :oldState
end

americanMindLogo 100