; Inspired by logo at:
; https://www.medicare.pt
to portugalMedicareLogo :height
	localmake "oldState turtleState
	localmake "crossSize :height * 0.345
	jumpForward :height / 2
	setPenSize 0
	setFillColor "#ae1022
	circle :height / 2
	setLineCap "round
	setPenSize :height * 0.174
	setPenColor "white
	localmake "center pos
	repeat 2 [
		jumpBackward :crossSize / 2
		forward :crossSize
		right 90
		jumpTo :center
	]
	setTurtleState :oldState
end

portugalMedicareLogo 100