; Inspired by flag at:
; https://en.wikipedia.org/wiki/File:Flag_of_the_Daza_People.svg
to bejaCongressFlag :height
	localmake "oldState turtleState
	localmake "width :height * 2
	localmake "redWidth :height / 2
	stripes :width :height ["#298b00 "#f3f108 "#0772f4]
	jumpLeft (:width - :redWidth) / 2
	stripes :redWidth :height ["#f0211b]
	setTurtleState :oldState
end

bejaCongressFlag 100