to drawHeart :height
	localmake "oldState turtleState
	setPenSize 0
	repeat 2 [
		drawArcLineShape [0 0
			[[45 0] [0.7] [-180 0.29] [0.4]]
		] :height * sign repcount - 1.5
	]

	setTurtleState :oldState
end

; Inspired by drawing at:
; https://www.youtube.com/watch?v=lIqHXG6zR48
to blueCovidMask :height
	localmake "oldState turtleState
	localmake "oldPos pos
	setPenSize :height * 0.04
	setPenColor "#00d
	setFillColor transparent
	repeat 2 [
		drawArcLineShape [0.38 0.59
			[[-53 0] [0.54] [-120 0.28] [-40 0.25] [-60 0.3]
			[-20 1]]
		] :height * sign repcount - 1.5
	]
	setPenSize 0
	jumpForward :height
	setFillGradient createRadialGradient pos :height createPList2 [
		[0 penColor] [1 mix penColor "black 0.3]
	]
	jumpTo :oldPos
	drawArcLineShape [0 0
		pathMirror [
			[-35 0.95] [-51 0.55] [-77 0] [0.60079999]
		]
	] :height
	
	setFillColor "#f20
	jumpForward :height * 0.41
	jumpRight :height * 0.272
	drawHeart :height * 0.25

	setFontSize :height * 0.2
	setFontFamily "arial
	setPenSize :height * 0.002
	setPenColor "black
	setLineJoinStyle "round
	jumpTo :oldPos
	right 90
	jumpLeft :height * 0.2
	jumpBackward :height * 0.2
	label "SAFE
	jumpLeft :height * 0.3
	jumpBackward :height * 0.3
	label "STAY	
	setTurtleState :oldState
end

setScreenColor "#ffd
blueCovidMask 100