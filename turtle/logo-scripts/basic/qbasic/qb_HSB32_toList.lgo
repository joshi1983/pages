; Similar to QB64's _HSB32 function except returns a WebLogo list.
; QB64's _HSB32 likely returns a 32-bit integer representing a color.
; The following returns a list representing a color.
to qb_HSB32_toList :hueDegrees :saturationPercent :brightnessPercent
	output hsvToRGB :hueDegrees / 360 :saturationPercent / 100 :brightnessPercent / 100
end